{
  "name": "@rc-component/mutate-observer",
  "version": "2.0.1",
  "description": "React MutateObserver Component",
  "keywords": [
    "react",
    "react-component",
    "mutate-observer"
  ],
  "homepage": "https://react-component.github.io/mutate-observer",
  "bugs": {
    "url": "https://github.com/react-component/mutate-observer/issues"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/react-component/mutate-observer.git"
  },
  "license": "MIT",
  "author": "574980606@qq.com",
  "main": "./lib/index",
  "module": "./es/index",
  "typings": "es/index.d.ts",
  "files": [
    "lib",
    "es",
    "dist"
  ],
  "scripts": {
    "build": "npm run docs:build",
    "compile": "father build",
    "deploy": "npm run gh-pages",
    "docs:build": "dumi build",
    "docs:deploy": "gh-pages -d docs-dist",
    "gh-pages": "cross-env GH_PAGES=1 npm run docs:build && npm run docs:deploy",
    "lint": "eslint src/ --ext .tsx,.ts",
    "lint:tsc": "tsc -p tsconfig.json --noEmit",
    "prepare": "dumi setup",
    "prepublishOnly": "npm run compile && rc-np",
    "prettier": "prettier --write --ignore-unknown .",
    "start": "dumi dev",
    "test": "umi-test",
    "test:coverage": "npm run test --coverage",
    "tsc": "tsc --noEmit",
    "watch": "father dev"
  },
  "dependencies": {
    "@rc-component/util": "^1.11.1"
  },
  "devDependencies": {
    "@rc-component/father-plugin": "^2.2.0",
    "@rc-component/np": "^1.0.4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^15.0.7",
    "@types/jest": "^29.5.14",
    "@types/node": "^26.0.1",
    "@types/react": "^18.3.31",
    "@types/react-dom": "^18.3.7",
    "@umijs/fabric": "^4.0.1",
    "cheerio": "1.0.0-rc.12",
    "cross-env": "^10.1.0",
    "dumi": "^2.4.35",
    "eslint": "^8.57.1",
    "eslint-plugin-jest": "^27.9.0",
    "eslint-plugin-unicorn": "^56.0.1",
    "father": "^4.6.23",
    "gh-pages": "^6.3.0",
    "glob": "^13.0.6",
    "prettier": "^3.9.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "typescript": "^5.9.3",
    "umi-test": "^1.9.7"
  },
  "peerDependencies": {
    "react": ">=16.9.0",
    "react-dom": ">=16.9.0"
  },
  "engines": {
    "node": ">=8.x"
  },
  "publishConfig": {
    "access": "public"
  }
}
